# WatchHive — copy to .env and fill in (never commit .env)

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# TMDB (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# TMDB API Read Access Token (Bearer) for server fetches to api.themoviedb.org/3 — same settings page as TMDB_API_KEY
AUTH_TOKEN=

# JWT for app session cookie (use a long random string in production)
JWT_SECRET=

# Canonical site URL when not on Vercel (metadata / absolute URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (optional — VAPID key pair; see web-push docs)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# mailto: or https: contact URL for push subscription
VAPID_SUBJECT=

# Optional: TV Maze (https://www.tvmaze.com/api)
TVMAZE_API_KEY=

# Optional: Watchmode (https://api.watchmode.com/) — streaming availability metadata; returns web URLs to
# services (subscriptions still required to watch). When set, /api/watch/watchmode-resolve can supply deeplinks
# where TMDB watch/providers does not expose a solid per-provider link. Omit to rely on TMDB + search fallbacks.
WATCHMODE_API_KEY=

# Optional: Amazon associate tag for outbound Prime links
NEXT_PUBLIC_AMAZON_ASSOCIATE_TAG=

# --- Supabase Edge Functions (Dashboard → Edge Functions → Secrets), not only Next.js .env ---
# CRON_SECRET          — shared secret header for scheduled jobs calling Edge Functions
# TMDB_API_KEY         — used by Edge functions that call TMDB (often same value as above)
# VAPID_PUBLIC_KEY     — for push-related cron paths (when applicable)
# VAPID_PRIVATE_KEY
# VAPID_SUBJECT        — optional
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected for Edge
